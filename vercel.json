{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd project19dribble1 && npm install",
  "buildCommand": "cd project19dribble1 && npm run build",
  "outputDirectory": "project19dribble1/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
