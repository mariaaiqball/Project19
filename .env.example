# Create a free account at https://resend.com and add an API key in Vercel:
# Project Settings -> Environment Variables
RESEND_API_KEY=re_your_api_key_here

# Where consultation form submissions are delivered
CONTACT_TO_EMAIL=info@theproject19.com

# Must use a verified sender in Resend for production.
# Resend's test sender works while you're setting up:
CONTACT_FROM_EMAIL=Project 19 <onboarding@resend.dev>
